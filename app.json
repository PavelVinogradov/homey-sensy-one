{
  "id": "com.sensyone.s1pro",
  "version": "0.3.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "platforms": ["local"],
  "name": { "en": "Sensy One" },
  "description": {
    "en": "Sensy-One S1 Pro Multi Sense presence and environmental sensor (ESPHome)."
  },
  "category": ["climate"],
  "brandColor": "#5cd6c0",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": { "name": "void", "email": "void@nixdev.net" },
  "drivers": [
    {
      "id": "s1-pro",
      "name": { "en": "S1 Pro Multi Sense" },
      "class": "sensor",
      "capabilities": [
        "alarm_motion",
        "measure_temperature",
        "measure_humidity",
        "measure_luminance",
        "measure_target_count"
      ],
      "platforms": ["local"],
      "connectivity": ["lan"],
      "discovery": "esphome-s1pro",
      "images": {
        "small": "/drivers/s1-pro/assets/images/small.png",
        "large": "/drivers/s1-pro/assets/images/large.png"
      },
      "pair": [
        { "id": "start" },
        { "id": "list_devices", "template": "list_devices", "navigation": { "next": "add_devices" } },
        { "id": "manual", "navigation": { "next": "add_devices" } },
        { "id": "add_devices", "template": "add_devices" }
      ],
      "settings": [
        {
          "id": "host",
          "type": "text",
          "label": { "en": "IP address / hostname" },
          "value": ""
        },
        {
          "id": "port",
          "type": "number",
          "label": { "en": "Native API port" },
          "value": 6053
        },
        {
          "id": "password",
          "type": "password",
          "label": { "en": "API password (optional)" },
          "value": ""
        },
        {
          "id": "firmware_current",
          "type": "label",
          "label": { "en": "Current firmware version" },
          "value": ""
        },
        {
          "id": "firmware_latest",
          "type": "label",
          "label": { "en": "Latest firmware version" },
          "value": ""
        }
      ]
    }
  ],
  "capabilities": {
    "measure_target_count": {
      "type": "number",
      "title": { "en": "Detected targets" },
      "units": { "en": "targets" },
      "icon": "assets/target_count.svg",
      "min": 0,
      "max": 3,
      "step": 1,
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false
    }
  },
  "flow": {
    "actions": [
      {
        "id": "install_firmware_update",
        "title": { "en": "Install firmware update" },
        "hint": { "en": "Triggers OTA firmware install on the S1 Pro sensor." },
        "args": [
          { "type": "device", "name": "device", "filter": "driver_id=s1-pro" }
        ]
      },
      {
        "id": "check_firmware_update",
        "title": { "en": "Check for firmware update" },
        "hint": { "en": "Asks the S1 Pro to check for a new firmware version." },
        "args": [
          { "type": "device", "name": "device", "filter": "driver_id=s1-pro" }
        ]
      }
    ]
  },
  "discovery": {
    "esphome-s1pro": {
      "type": "mdns-sd",
      "mdns-sd": { "name": "esphomelib", "protocol": "tcp" },
      "id": "{{txt.mac}}",
      "conditions": [
        [
          {
            "field": "txt.project_name",
            "match": { "type": "string", "value": "Sensy-One.S1 Pro Multi Sense" }
          }
        ]
      ]
    }
  }
}
