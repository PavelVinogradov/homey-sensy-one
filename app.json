{
  "id": "net.nixdev.sensyone",
  "version": "0.8.1",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "CommSensyOne"
  },
  "description": {
    "en": "Unofficial Homey integration for Sensy-One sensors: S1 Pro Multi Sense (mmWave presence, LED, buzzer) and AirDot (air quality display). Community project, provided AS-IS."
  },
  "tags": {
    "en": ["sensy-one", "mmwave", "presence", "air quality", "esphome", "radar", "co2", "pm2.5"]
  },
  "category": [
    "security",
    "climate"
  ],
  "brandColor": "#5cd6c0",
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": {
    "name": "Pavel Vinogradov"
  },
  "license": "MIT",
  "homepage": "https://github.com/PavelVinogradov/homey-sensy-one",
  "source": "https://github.com/PavelVinogradov/homey-sensy-one",
  "bugs": {
    "url": "https://github.com/PavelVinogradov/homey-sensy-one/issues"
  },
  "drivers": [
    {
      "id": "s1-pro",
      "name": {
        "en": "S1 Pro Multi Sense"
      },
      "class": "sensor",
      "capabilities": [
        "alarm_motion",
        "measure_temperature",
        "measure_humidity",
        "measure_luminance",
        "measure_target_count",
        "measure_co2",
        "measure_co2_equivalent",
        "onoff",
        "dim",
        "light_hue",
        "light_saturation",
        "light_mode"
      ],
      "capabilitiesOptions": {
        "onoff": {
          "title": {
            "en": "LED"
          }
        },
        "dim": {
          "title": {
            "en": "LED Brightness"
          }
        },
        "light_hue": {
          "title": {
            "en": "LED Color"
          }
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "discovery": "esphome-s1pro",
      "images": {
        "small": "/drivers/s1-pro/assets/images/small.png",
        "large": "/drivers/s1-pro/assets/images/large.png"
      },
      "pair": [
        {
          "id": "start"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "manual",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "repair": [
        {
          "id": "repair"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": { "en": "Device connection" },
          "children": [
            {
              "id": "host",
              "type": "text",
              "label": { "en": "IP address / hostname" },
              "value": ""
            },
            {
              "id": "port",
              "type": "number",
              "label": { "en": "Native API port" },
              "value": 6053
            },
            {
              "id": "password",
              "type": "password",
              "label": { "en": "API password (optional)" },
              "value": ""
            }
          ]
        },
        {
          "type": "group",
          "label": { "en": "Device firmware" },
          "children": [
            {
              "id": "firmware_current",
              "type": "label",
              "label": { "en": "Current version" },
              "value": ""
            },
            {
              "id": "firmware_latest",
              "type": "label",
              "label": { "en": "Latest version" },
              "value": ""
            }
          ]
        },
        {
          "type": "group",
          "label": { "en": "Device settings" },
          "children": [
            {
              "id": "radar_single_target",
              "type": "checkbox",
              "label": { "en": "Single target mode" },
              "hint": {
                "en": "When enabled, the radar tracks only 1 target. Disable to detect up to 3 targets simultaneously."
              },
              "value": false
            },
            {
              "id": "radar_flip_y_axis",
              "type": "checkbox",
              "label": { "en": "Flip Y axis" },
              "hint": {
                "en": "Enable if sensor is mounted upside-down or facing the opposite direction."
              },
              "value": false
            },
            {
              "id": "detection_range",
              "type": "number",
              "label": { "en": "Detection range (cm)" },
              "hint": {
                "en": "Maximum radar detection distance. 0–1800 cm."
              },
              "value": 600,
              "attr": { "min": 0, "max": 1800, "step": 1 }
            },
            {
              "id": "any_presence_delay",
              "type": "number",
              "label": { "en": "Presence clear delay (s)" },
              "hint": {
                "en": "Seconds to wait before reporting absence after targets disappear. 0–3600 s."
              },
              "value": 0,
              "attr": { "min": 0, "max": 3600, "step": 1 }
            }
          ]
        }
      ]
    },
    {
      "id": "airdot",
      "name": {
        "en": "AirDot"
      },
      "class": "sensor",
      "capabilities": [
        "measure_temperature",
        "measure_humidity",
        "measure_luminance",
        "measure_co2",
        "measure_pressure",
        "measure_pm1",
        "measure_pm25",
        "measure_pm4",
        "measure_pm10",
        "measure_voc",
        "measure_nox"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "discovery": "esphome-airdot",
      "images": {
        "small": "/drivers/airdot/assets/images/small.png",
        "large": "/drivers/airdot/assets/images/large.png"
      },
      "pair": [
        {
          "id": "start"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "manual",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "repair": [
        {
          "id": "repair"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": { "en": "Device connection" },
          "children": [
            {
              "id": "host",
              "type": "text",
              "label": { "en": "IP address / hostname" },
              "value": ""
            },
            {
              "id": "port",
              "type": "number",
              "label": { "en": "Native API port" },
              "value": 6053
            },
            {
              "id": "password",
              "type": "password",
              "label": { "en": "API password (optional)" },
              "value": ""
            }
          ]
        },
        {
          "type": "group",
          "label": { "en": "Device firmware" },
          "children": [
            {
              "id": "firmware_current",
              "type": "label",
              "label": { "en": "Current version" },
              "value": ""
            },
            {
              "id": "firmware_latest",
              "type": "label",
              "label": { "en": "Latest version" },
              "value": ""
            }
          ]
        }
      ]
    }
  ],
  "capabilities": {
    "measure_co2_equivalent": {
      "type": "number",
      "title": {
        "en": "CO₂ Equivalent (estimated)"
      },
      "units": {
        "en": "ppm"
      },
      "decimals": 0,
      "min": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false,
      "icon": "assets/co2.svg"
    },
    "measure_target_count": {
      "type": "number",
      "title": {
        "en": "Detected targets"
      },
      "units": {
        "en": "targets"
      },
      "icon": "assets/target_count.svg",
      "min": 0,
      "max": 3,
      "step": 1,
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false
    },
    "measure_pm1": {
      "type": "number",
      "title": {
        "en": "PM1"
      },
      "units": {
        "en": "µg/m³"
      },
      "decimals": 1,
      "min": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false
    },
    "measure_pm25": {
      "type": "number",
      "title": {
        "en": "PM2.5"
      },
      "units": {
        "en": "µg/m³"
      },
      "decimals": 1,
      "min": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false
    },
    "measure_pm4": {
      "type": "number",
      "title": {
        "en": "PM4"
      },
      "units": {
        "en": "µg/m³"
      },
      "decimals": 1,
      "min": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false
    },
    "measure_pm10": {
      "type": "number",
      "title": {
        "en": "PM10"
      },
      "units": {
        "en": "µg/m³"
      },
      "decimals": 1,
      "min": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false
    },
    "measure_voc": {
      "type": "number",
      "title": {
        "en": "VOC Index"
      },
      "units": {
        "en": "index"
      },
      "decimals": 0,
      "min": 0,
      "max": 500,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false
    },
    "measure_nox": {
      "type": "number",
      "title": {
        "en": "NOx Index"
      },
      "units": {
        "en": "index"
      },
      "decimals": 0,
      "min": 1,
      "max": 500,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "uiQuickAction": false
    }
  },
  "flow": {
    "triggers": [
      {
        "id": "target_count_changed",
        "title": {
          "en": "Number of detected targets changed"
        },
        "hint": {
          "en": "Fires when the number of detected targets changes."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=s1-pro"
          }
        ],
        "tokens": [
          {
            "name": "count",
            "type": "number",
            "title": {
              "en": "Target count"
            }
          }
        ]
      },
      {
        "id": "target_count_became",
        "title": {
          "en": "Number of detected targets became"
        },
        "titleFormatted": {
          "en": "Number of detected targets became [[count]]"
        },
        "hint": {
          "en": "Fires when the number of detected targets changes to a specific value."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=s1-pro"
          },
          {
            "type": "number",
            "name": "count",
            "title": {
              "en": "Number of targets"
            },
            "min": 0,
            "max": 3
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "target_count_condition",
        "title": {
          "en": "Number of targets !{{is|is not}}"
        },
        "titleFormatted": {
          "en": "Number of targets !{{is|is not}} [[operator]] [[count]]"
        },
        "hint": {
          "en": "Check current number of detected targets."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=s1-pro"
          },
          {
            "type": "dropdown",
            "name": "operator",
            "title": {
              "en": "Comparison"
            },
            "values": [
              {
                "id": "lt",
                "label": {
                  "en": "less than"
                }
              },
              {
                "id": "lte",
                "label": {
                  "en": "less than or equal to"
                }
              },
              {
                "id": "eq",
                "label": {
                  "en": "equal to"
                }
              },
              {
                "id": "gte",
                "label": {
                  "en": "greater than or equal to"
                }
              },
              {
                "id": "gt",
                "label": {
                  "en": "greater than"
                }
              }
            ]
          },
          {
            "type": "number",
            "name": "count",
            "title": {
              "en": "Number of targets"
            },
            "min": 0,
            "max": 3
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "play_sound_signal",
        "title": {
          "en": "Play sound signal"
        },
        "titleFormatted": {
          "en": "Play sound signal [[signal]]"
        },
        "hint": {
          "en": "Play a predefined buzzer sound pattern on the S1 Pro."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=s1-pro"
          },
          {
            "type": "dropdown",
            "name": "signal",
            "title": {
              "en": "Signal"
            },
            "values": [
              {
                "id": "short_beep",
                "label": {
                  "en": "Short beep"
                }
              },
              {
                "id": "double_beep",
                "label": {
                  "en": "Double beep"
                }
              },
              {
                "id": "triple_beep",
                "label": {
                  "en": "Triple beep"
                }
              },
              {
                "id": "long_beep",
                "label": {
                  "en": "Long beep"
                }
              },
              {
                "id": "alert",
                "label": {
                  "en": "Alert (rapid)"
                }
              },
              {
                "id": "success",
                "label": {
                  "en": "Success (rising)"
                }
              },
              {
                "id": "warning",
                "label": {
                  "en": "Warning (descending)"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "led_turn_off",
        "title": {
          "en": "Turn off LED"
        },
        "hint": {
          "en": "Turns off the WS2812B LED on the S1 Pro."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=s1-pro"
          }
        ]
      },
      {
        "id": "install_firmware_update",
        "title": {
          "en": "Install firmware update"
        },
        "hint": {
          "en": "Triggers OTA firmware install on the S1 Pro sensor."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=s1-pro"
          }
        ]
      },
      {
        "id": "check_firmware_update",
        "title": {
          "en": "Check for firmware update"
        },
        "hint": {
          "en": "Asks the S1 Pro to check for a new firmware version."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=s1-pro"
          }
        ]
      },
      {
        "id": "airdot_show_alert",
        "title": {
          "en": "Show alert on display"
        },
        "titleFormatted": {
          "en": "Show [[title]]: [[message]] for [[duration]]s (sound: [[sound_enabled]]) on AirDot display"
        },
        "hint": {
          "en": "Show a custom title and message on the AirDot display for a set duration."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=airdot"
          },
          {
            "type": "text",
            "name": "title",
            "title": {
              "en": "Title"
            },
            "placeholder": {
              "en": "Alert"
            }
          },
          {
            "type": "text",
            "name": "message",
            "title": {
              "en": "Message"
            },
            "placeholder": {
              "en": "..."
            }
          },
          {
            "type": "number",
            "name": "duration",
            "title": {
              "en": "Duration (seconds, 0 = permanent)"
            },
            "min": 0,
            "max": 3600,
            "step": 1,
            "value": 10
          },
          {
            "type": "checkbox",
            "name": "sound_enabled",
            "title": {
              "en": "Play sound"
            },
            "value": false
          }
        ]
      },
      {
        "id": "airdot_clear_alert",
        "title": {
          "en": "Clear display alert"
        },
        "hint": {
          "en": "Dismiss the current alert overlay on the AirDot display."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=airdot"
          }
        ]
      },
      {
        "id": "airdot_install_firmware_update",
        "title": {
          "en": "Install firmware update"
        },
        "hint": {
          "en": "Triggers OTA firmware install on the AirDot sensor."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=airdot"
          }
        ]
      },
      {
        "id": "airdot_check_firmware_update",
        "title": {
          "en": "Check for firmware update"
        },
        "hint": {
          "en": "Asks the AirDot to check for a new firmware version."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=airdot"
          }
        ]
      }
    ]
  },
  "api": {
    "getDevices": {
      "method": "GET",
      "path": "/devices"
    },
    "setDeviceHost": {
      "method": "POST",
      "path": "/device/:id/host"
    }
  },
  "discovery": {
    "esphome-airdot": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "esphomelib",
        "protocol": "tcp"
      },
      "id": "{{txt.mac}}",
      "conditions": [
        [
          {
            "field": "txt.project_name",
            "match": {
              "type": "string",
              "value": "sensy-one.AirDot"
            }
          }
        ]
      ]
    },
    "esphome-s1pro": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "esphomelib",
        "protocol": "tcp"
      },
      "id": "{{txt.mac}}",
      "conditions": [
        [
          {
            "field": "txt.project_name",
            "match": {
              "type": "string",
              "value": "Sensy-One.S1 Pro Multi Sense"
            }
          }
        ]
      ]
    }
  }
}